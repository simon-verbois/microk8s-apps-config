# Template: review and replace placeholder values before deployment.
# Source: 06-ingressroute.yaml
# This IngressRoute is more secure than the default ingress
# To use this IngressRoute, please refer to: the Traefik configuration used in your cluster
---
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: filebrowser-ingressroute
  namespace: filebrowser
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`filebrowser.example.com`)
      kind: Rule
      services:
        - name: filebrowser-service
          port: http
      middlewares:
        - name: rate-limit
          namespace: traefik
        - name: security-headers
          namespace: traefik
        - name: geoblock
          namespace: traefik

  tls:
    certResolver: ovhresolver
    domains:
      - main: "filebrowser.example.com"
    options:
      name: tls-profile
      namespace: traefik

